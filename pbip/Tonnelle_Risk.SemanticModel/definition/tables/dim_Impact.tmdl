/// Impact axis dim table (1-5 numeric + text label). Companion to dim_Probability. Used as the Page 1 P-I matrix Rows axis. Provides a stable filter-context value for SELECTEDVALUE in empty cells where Risk_Register has no matching rows. ImpactLabel added 2026-05-24 so the matrix axis renders "Very Low / Low / Med / High / Very High" instead of "1 / 2 / 3 / 4 / 5".
table dim_Impact
	lineageTag: 77a7b8c9-0007-4000-8000-000000000001

	column Impact
		dataType: int64
		formatString: 0
		lineageTag: 77a7b8c9-0007-4000-8000-000000000002
		summarizeBy: none
		isNameInferred
		sourceColumn: [Impact]

		annotation SummarizationSetBy = User

	column ImpactLabel
		dataType: string
		lineageTag: 77a7b8c9-0007-4000-8000-000000000003
		summarizeBy: none
		isNameInferred
		sourceColumn: [ImpactLabel]
		sortByColumn: Impact

	partition dim_Impact = calculated
		mode: import
		source =
				SELECTCOLUMNS (
				    GENERATESERIES ( 1, 5 ),
				    "Impact", [Value],
				    "ImpactLabel",
				        SWITCH (
				            [Value],
				            1, "Very Low",
				            2, "Low",
				            3, "Med",
				            4, "High",
				            5, "Very High"
				        )
				)

